  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#525260",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#6E6E78"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#6E6E78"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#B19CD9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage type",
      "scope": [
        "storage.type.function",
        "storage.type.class",
        "storage.type.struct"
      ],
      "settings": {
        "foreground": "#B19CD9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#D8939E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant other",
      "scope": [
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#D8939E"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#D9B872"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#E5C99A"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#7BC9A7"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7FAED9"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#7FAED9"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#7BC9A7"
      }
    },
    {
      "name": "Interface / Enum",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#7BC9A7"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#9DB9D9"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other"
      ],
      "settings": {
        "foreground": "#DCDCE3"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#DCDCE3"
      }
    },
    {
      "name": "This / self",
      "scope": [
        "variable.language",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#B19CD9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "tag.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#B19CD9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorator name",
      "scope": [
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#B19CD9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#D9939E"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#9DB9D9"
      }
    },
    {
      "name": "Tag attribute value",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#D9B872"
      }
    },
    {
      "name": "Heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#7FAED9"
      }
    },
    {
      "name": "Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E6E6EB",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#E6E6EB",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#7FAED9",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#D9B872"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#4ADE80"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#F87171"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D9B872"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F87171"
      }
    },
    {
      "name": "JSON property",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.json string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#9DB9D9"
      }
    },
    {
      "name": "YAML key",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#9DB9D9"
      }
    },
    {
      "name": "CSS class",
      "scope": [
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#7BC9A7"
      }
    },
    {
      "name": "CSS id",
      "scope": [
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#D8939E"
      }
    },
    {
      "name": "CSS pseudo",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#B19CD9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#9DB9D9"
      }
    },
    {
      "name": "CSS value",
      "scope": [
        "support.constant.property-value.css",
        "constant.numeric.css"
